# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ghana_mining_lcm?schema=public"

# NextAuth / Auth.js v5
# AUTH_SECRET is required in production — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST=true  # Set this on Render/Railway/etc.

# App
NEXT_PUBLIC_APP_NAME="Ghana Mining Local Content Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
